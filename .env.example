# Copiá este archivo a ".env" y completá los valores reales.
# ".env" nunca se sube a git (ver .gitignore).

# Cadena de conexión a la base de datos PostgreSQL.
# En local: la que te da tu Postgres local o el proxy de Railway.
# En producción (Railway): Railway la inyecta automáticamente si
# la base de datos vive en el mismo proyecto.
DATABASE_URL="postgresql://usuario:password@localhost:5432/money_web"

# Puerto en el que arranca el servidor Express en LOCAL.
# En Railway no se usa este valor: Railway inyecta su propia
# variable PORT y el servidor debe escucharla (ver server/index.ts
# cuando se cree en la Fase 3).
PORT=4000

# Secreto usado para firmar los tokens JWT de sesión.
# Generá uno propio (no uses este placeholder ni en local ni en prod).
JWT_SECRET="cambia-este-valor-por-uno-propio-y-largo"
